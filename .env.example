# OpenAI
# Obtenha sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_REASONING_EFFORT=medium

# Avaliacao RAGAS
RAGAS_TIMEOUT_SECONDS=600
RAGAS_MAX_WORKERS=4

# Documentos
DOCS_DIR=../docs/

# Recuperacao
RETRIEVER_K=3

# ChromaDB
# Use um diretorio novo ao trocar o modelo de embeddings.
CHROMA_PERSIST_DIR=./chroma_hybrid_db_openai
CHROMA_COLLECTION_NAME=hybrid_collection_openai

# LangSmith (opcional)
# Obtenha sua chave em: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=benchmark-hybrid-rag
